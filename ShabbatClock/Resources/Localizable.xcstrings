    "Shabbat begins tomorrow" : {

    },
    "Shabbat Clock" : {
      "localizations" : {
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "שעון שבת"
          }
        }
      }
    },
    "SHABBAT CLOCK" : {
      "extractionState" : "stale",
      "localizations" : {
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "שעון שבת"
          }
        }
      }
    },
    "Shabbat Clock needs alarm access to wake you for tefilah. Alarms will sound even when your phone is on Do Not Disturb — so you can put your phone down for all of Shabbat." : {
      "localizations" : {
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "שעון שבת צריך גישה להתראות כדי להעיר אותך לתפילה. ההתראות יישמעו גם כשהטלפון במצב נא לא להפריע — כך שתוכל להניח את הטלפון לכל השבת."
          }
        }
      }
    },
    "Shabbat Clock uses iOS's built-in alarm. To stop it on time, the app schedules a second silent alarm that takes over and ends the ring. The result is a clean shut-off — but iOS will still try to vibrate unless you turn vibration off." : {
      "extractionState" : "stale",
      "localizations" : {
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "שעון שבת משתמש בהתראה המובנית של iOS. כדי לעצור אותה בזמן, האפליקציה קובעת התראה שקטה שניה שמשתלטת ומסיימת את הצלצול. התוצאה היא כיבוי נקי — אך iOS עדיין ינסה לרטוט אלא אם כן תכבה את הרטט."
          }
        }
      }
    },
    "Shabbat Clock uses your location to calculate precise zmanim (halachic times) for your area — including candle lighting and havdalah times." : {
      "localizations" : {
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "שעון שבת משתמש במיקום שלך כדי לחשב זמנים הלכתיים מדויקים לאזורך — כולל זמני הדלקת נרות והבדלה."
          }
        }
      }
    },
    "Shabbat in %lld days" : {

    },
    "Shabbat Melodies" : {
      "extractionState" : "manual",
      "localizations" : {
        "he" : {
          "stringUnit" : {
