      "localizations" : {
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "התשלום יחויב לחשבון Apple ID שלך באישור הרכישה. המנוי מתחדש אוטומטית אלא אם בוטל לפחות 24 שעות לפני תום התקופה הנוכחית. ניתן לנהל ולבטל מנויים בהגדרות חשבון App Store."
