        }
      }
    },
    "Your alarm stops automatically after the time you choose. This requires notification permission." : {
      "localizations" : {
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ההתראה נכבית אוטומטית אחרי הזמן שבחרת. נדרשת הרשאת התראות."
          }
        }
      }
    },
    "Your alarm will use a 30-second notification sound. To enable full alarm features — longer durations, Do Not Disturb override, and Shabbat mode — allow alarms in Settings." : {
      "localizations" : {
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ההתראה תשתמש בצליל של 30 שניות. כדי לאפשר תכונות מלאות — משך ארוך יותר, עקיפת מצב לא להפריע ומצב שבת — אפשר התראות בהגדרות."
          }
