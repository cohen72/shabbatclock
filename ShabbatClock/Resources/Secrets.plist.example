<?xml version="1.0" encoding="UTF-8"?>
<!--
  Template for Secrets.plist. Copy this file to Secrets.plist (same directory) and
  fill in real values. Secrets.plist is gitignored and MUST NOT be committed.

  After copying, add Secrets.plist to the Xcode project:
    File → Add Files to "ShabbatClock" → select Secrets.plist
    (Ensure "ShabbatClock" target membership is checked, "Copy items if needed" off.)
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>MixpanelProjectToken</key>
	<string>REPLACE_WITH_YOUR_MIXPANEL_TOKEN</string>
</dict>
</plist>
